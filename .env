# =========================
# LOB SIM (Binance USD-M)
# =========================

# --- Credentials (NOT required for public market data; keep empty unless you later trade) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
# --- Endpoints ---
# Mainnet USD-M Futures
BINANCE_FAPI_BASE=https://fapi.binance.com
BINANCE_FWS_BASE=wss://fstream.binance.com

# (Optional) If you ever want testnet later:
# BINANCE_FAPI_BASE=https://demo-fapi.binance.com
# BINANCE_FWS_BASE=wss://fstream.binancefuture.com

# --- Symbols / streams ---
# Comma-separated
SYMBOLS=BTCUSDT

# Depth + trades (combined streams will be built as: <symbol.lower()><suffix>)
DEPTH_STREAM_SUFFIX=@depth@100ms
TRADE_STREAM_SUFFIX=@aggTrade

# REST snapshot depth limit: 5/10/20/50/100/500/1000
SNAPSHOT_LIMIT=1000

# Keep only top N levels in memory for features/metrics (still applies full diffs)
BOOK_TOP_N=20

# --- Collector ---
COLLECT_SECONDS=30
RECORD_DIR=./data
RECORD_FORMAT=ndjson
RECORD_GZIP=0
RECORD_FLUSH_EVERY=300

# --- Networking / robustness ---
HTTP_TIMEOUT=10
HTTP_RETRIES=2

# Throttle REST calls (snapshot/exchangeInfo). Websocket is separate.
RATE_LIMIT_REQ_PER_SEC=8

WS_PING_INTERVAL=180
WS_PING_TIMEOUT=600
WS_RECONNECT_MAX_SEC=30

# If book diff sequence breaks, resnapshot immediately
RESYNC_ON_GAP=1

# --- Simulation (offline replay) ---
SIM_SEED=1

# Latency model (applies to strategy actions in replay)
SIM_ORDER_LATENCY_MS=10
SIM_CANCEL_LATENCY_MS=10

# Simple maker strategy defaults
MM_ENABLED=1
MM_REQUOTE_MS=40
MM_ORDER_QTY=0.001
MM_MAX_POSITION=0.05
MM_HALF_SPREAD_BPS=0.05
MM_SKEW_BPS_PER_UNIT=10.0

# Fees (bps). Maker can be negative (rebate) depending on venue/product; tune later.
FEES_MAKER_BPS=-0.2
FEES_TAKER_BPS=4.0

# --- Logging ---
LOG_LEVEL=INFO
